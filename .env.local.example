# Variaveis pra dev local com `npx vercel dev`. NAO COMMITAR.
# Copiar pra .env.local (que esta no .gitignore via *.local) e
# preencher com os valores reais. Mesmas chaves devem ir pro
# painel da Vercel (Production + Preview).
#
# IMPORTANTE: nenhuma dessas variaveis pode ter prefixo `VITE_` —
# isso expoe o valor pro bundle do front e a service_role vaza.

SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

RESEND_API_KEY=re_...

